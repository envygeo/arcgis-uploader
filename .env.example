# --- ArcGIS Enterprise -----------------------------------------------------
PORTAL_URL=https://maps.gov.yk.ca/portal
ARCGIS_USERNAME=svc_uploader
ARCGIS_PASSWORD=change-me
# Override only for standalone (non-federated) ArcGIS Server.
# Default: $PORTAL_URL/sharing/rest/generateToken
#GENERATE_TOKEN_URL=$PORTAL_URL/sharing/rest/generateToken

# --- Target layers -----------------------------------------------------------
# One editable hosted feature layer per geometry family. Leave one blank to
# skip that family (its features are reported back as skipped, not appended).
# All three may live in the same FeatureServer as layers 0/1/2.
TARGET_LAYER_POINT=https://maps.gov.yk.ca/server/rest/services/Hosted/project_features/FeatureServer/0
TARGET_LAYER_POLYLINE=https://maps.gov.yk.ca/server/rest/services/Hosted/project_features/FeatureServer/1
TARGET_LAYER_POLYGON=https://maps.gov.yk.ca/server/rest/services/Hosted/project_features/FeatureServer/2

# --- Behaviour ---------------------------------------------------------------
# Field on the target layers that receives the value from the web form.
PROJECT_ID_FIELD=project_id
# Field on the target layers that records who uploaded.
USERNAME_FIELD=uploaded_by
# Where the username comes from, in order of preference:
#   1. `username` form field sent by the example form or a third-party app.
#      In production, have the host app fill it from its authenticated user;
#      do not treat a user-typed value as an audit control. Set
#      ALLOW_CLIENT_USERNAME=false to ignore it.
#   2. this header, set by the SSO/reverse proxy in front of the app
#   3. the literal "unknown" (bare development runs)
USERNAME_HEADER=X-Forwarded-User
ALLOW_CLIENT_USERNAME=true
# Regex a submitted project ID must match (Python re syntax).
#PROJECT_ID_PATTERN=^[\w][\w\- .]{0,63}$
# Refuse to append a feature when the destination already has the same id
# field value and a matching Shape within this many metres. By default the
# id field is PROJECT_ID_FIELD; set DUPLICATE_ID_FIELD=yesab_id if the form
# value should be checked/written against that field instead.
DUPLICATE_DETECTION=true
#DUPLICATE_ID_FIELD=yesab_id
DUPLICATE_TOLERANCE_M=1.0
# Optional extra read-only layers to include in the duplicate check. The
# target layer is still checked first using DUPLICATE_ID_FIELD. Use JSON for
# structured .env values: each object maps the submitted project ID to that
# layer's id field.
#DUPLICATE_COMPARE_LAYERS=[{"id_field":"attr_yesab_proj","url":"https://maps.gov.yk.ca/server/rest/services/ENV_YESAB/YESAB_Projects/FeatureServer/3"},{"id_field":"attr_yesab_proj","url":"https://maps.gov.yk.ca/server/rest/services/ENV_YESAB/YESAB_Projects/FeatureServer/4"},{"id_field":"attr_yesab_proj","url":"https://maps.gov.yk.ca/server/rest/services/ENV_YESAB/YESAB_Projects/FeatureServer/5"}]
MAX_UPLOAD_MB=200
# GDAL/pyogrio option: allow shapefiles with a missing .shx index to be read
# by rebuilding the index. Useful when users upload incomplete shapefile zips.
SHAPE_RESTORE_SHX=YES
# EPSG code assumed when an upload has no coordinate system (e.g. a shapefile
# missing its .prj). Unset = reject such uploads with an explanatory error.
#DEFAULT_SOURCE_EPSG=4326
# true = run the whole pipeline but never contact ArcGIS; the response reports
# what would have been appended, plus a sample Esri JSON feature.
DRY_RUN=false
# Optional basemap for the preview map (example 2): an XYZ tile template in
# Web Mercator. A portal-hosted tiled MapServer works directly, e.g.
# https://maps.gov.yk.ca/server/rest/services/Basemap/MapServer/tile/{z}/{y}/{x}
#BASEMAP_URL=
